generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Core Enums ───────────────────────────────────────────────────────────────

enum UserType {
  pro
  client
  admin
}

enum SubscriptionTier {
  starter
  standard
  pro
}

enum SubscriptionStatus {
  active
  canceled
  past_due
}

enum Availability {
  available
  busy
  unavailable
}

enum ProjectStatus {
  under_review
  planning
  active
  on_hold
  completed
  cancelled
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

enum EscrowStatus {
  awaiting_deposit
  held_in_escrow
  disputed
  released
  refunded
}

enum DeliverableType {
  report
  document
  design
  other
}

enum SkillLevel {
  beginner
  intermediate
  advanced
  expert
}

enum CallType {
  video
  audio
}

enum ScheduledCallStatus {
  pending
  completed
  cancelled
}

// ─── Inquiry Enums ────────────────────────────────────────────────────────────

enum InquiryStatus {
  new
  reviewed
  responded
  accepted
  declined
}

// ─── Proposal Enums ───────────────────────────────────────────────────────────

enum ProposalStatus {
  draft
  sent
  accepted
  rejected
  expired
}

// ─── Contract Enums ───────────────────────────────────────────────────────────

enum ContractStatus {
  draft
  sent
  signed
  expired
  cancelled
}

// ─── Retainer Enums ───────────────────────────────────────────────────────────

enum RetainerStatus {
  active
  paused
  cancelled
  completed
}

// ─── Campaign Enums ───────────────────────────────────────────────────────────

enum CampaignStatus {
  draft
  active
  paused
  completed
  cancelled
}

enum CampaignPlatform {
  meta
  google
  linkedin
  tiktok
  email
  seo
  other
}

// ─── Content Enums ────────────────────────────────────────────────────────────

enum ContentType {
  post
  ad
  email
  video
  blog
  story
  other
}

enum ContentStatus {
  draft
  pending_approval
  approved
  scheduled
  published
  rejected
}

// ─── Asset Enums ──────────────────────────────────────────────────────────────

enum AssetType {
  logo
  brand_guideline
  creative
  copy
  video
  font
  other
}

// ─── Deliverable Approval ─────────────────────────────────────────────────────

enum ApprovalStatus {
  pending_review
  approved
  revision_requested
}

// ─── Team Role ────────────────────────────────────────────────────────────────

enum TeamRole {
  owner
  manager
  contributor
}

// ─── Report Cadence ───────────────────────────────────────────────────────────

enum ReportCadence {
  weekly
  monthly
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  name               String
  password           String?
  userType           UserType           @default(client)
  image              String?
  emailVerified      DateTime?
  country            String?
  city               String?
  timezone           String             @default("Europe/London")
  stripeCustomerId   String?
  stripeAccountId    String?            // Stripe Connect account for pros
  subscriptionTier   SubscriptionTier   @default(starter)
  subscriptionStatus SubscriptionStatus @default(active)
  
  // Notification Preferences
  emailNotifications  Boolean            @default(true)
  projectUpdates      Boolean            @default(true)
  newInquiries        Boolean            @default(true)
  paymentReceived     Boolean            @default(true)
  reportReady         Boolean            @default(true)
  proMessages         Boolean            @default(true)
  marketingEmails     Boolean            @default(false)

  // AI usage tracking
  aiRequestsToday   Int                @default(0)
  aiLastRequestDate DateTime?

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  proProfile         ProProfile?
  projectsAsPro      Project[]          @relation("ProProjects")
  projectsAsClient   Project[]          @relation("ClientProjects")
  invoicesAsPro      Invoice[]          @relation("ProInvoices")
  invoicesAsClient   Invoice[]          @relation("ClientInvoices")
  scheduledCalls     ScheduledCall[]    @relation("ProScheduledCalls")

  // Proposals
  proposalsAsPro     Proposal[]         @relation("ProProposals")
  notifications      Notification[]
  proposalsAsClient  Proposal[]         @relation("ClientProposals")

  // Contracts
  contractsAsPro     Contract[]         @relation("ProContracts")
  contractsAsClient  Contract[]         @relation("ClientContracts")

  // Inquiries (interest expressions)
  inquiriesAsPro     Inquiry[]          @relation("ProInquiries")
  inquiriesAsClient  Inquiry[]          @relation("ClientInquiries")

  // Retainers
  retainersAsPro     RetainerAgreement[] @relation("ProRetainers")
  retainersAsClient  RetainerAgreement[] @relation("ClientRetainers")

  // Time entries
  timeEntries        TimeEntry[]

  // Campaigns
  campaignsAsPro     Campaign[]         @relation("ProCampaigns")

  // Content items
  contentItems       ContentItem[]

  // Brand assets
  brandAssets        BrandAsset[]

  // Briefs submitted as client
  briefs             ProjectBrief[]

  // Team memberships
  agencyMembers      TeamMember[]       @relation("AgencyTeam")
  memberOf           TeamMember[]       @relation("MemberOf")

  // Scheduled reports
  scheduledReports   ScheduledReport[]

  // Deliverable approvals
  deliverableApprovals DeliverableApproval[]

  // Messaging
  sentMessages         Message[]          @relation("SentMessages")
  receivedMessages     Message[]          @relation("ReceivedMessages")
}

model ProProfile {
  id             String          @id @default(cuid())
  userId         String          @unique
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio            String
  specialties    String[]
  location       String
  website        String?
  linkedIn       String?
  portfolio      String?
  hourlyRate     Float?
  monthlyRate    Float?
  availability   Availability    @default(available)
  rating         Float           @default(0)
  reviewCount    Int             @default(0)
  verified       Boolean         @default(false)

  skills         Skill[]
  certifications Certification[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Skill {
  id        String     @id @default(cuid())
  name      String
  level     SkillLevel
  profileId String
  profile   ProProfile @relation(fields: [profileId], references: [id])
}

model Certification {
  id           String     @id @default(cuid())
  name         String
  issuer       String
  issueDate    DateTime
  expiryDate   DateTime?
  credentialId String?
  profileId    String
  profile      ProProfile @relation(fields: [profileId], references: [id])
}

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String
  category     String?
  timeline     String?
  proId        String?
  pro          User?         @relation("ProProjects", fields: [proId], references: [id], onDelete: SetNull)
  clientId     String
  client       User          @relation("ClientProjects", fields: [clientId], references: [id], onDelete: Cascade)
  status       ProjectStatus @default(under_review)
  startDate    DateTime?     @default(now())
  endDate      DateTime?
  budget       Float?
  currency     String        @default("GBP")
  country      String?

  milestones   Milestone[]
  deliverables Deliverable[]
  invoices     Invoice[]
  campaigns    Campaign[]
  contentItems ContentItem[]
  brandAssets  BrandAsset[]
  timeEntries  TimeEntry[]
  brief        ProjectBrief?
  proposals    Proposal[]
  contracts    Contract[]
  inquiries    Inquiry[]
  scheduledReports ScheduledReport[]
  messages     Message[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Milestone {
  id          String    @id @default(cuid())
  title       String
  description String
  dueDate     DateTime
  status      String    @default("pending") // pending, in-progress, completed
  completedAt DateTime?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
}

model Deliverable {
  id           String          @id @default(cuid())
  title        String
  description  String
  type         DeliverableType
  fileUrl      String?
  deliveredAt  DateTime?
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id])

  // Approval workflow
  approvalStatus  ApprovalStatus @default(pending_review)
  approvedAt      DateTime?
  revisionNote    String?
  approvals       DeliverableApproval[]
}

model DeliverableApproval {
  id             String         @id @default(cuid())
  deliverableId  String
  deliverable    Deliverable    @relation(fields: [deliverableId], references: [id])
  reviewerId     String
  reviewer       User           @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  status         ApprovalStatus
  note           String?
  createdAt      DateTime       @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  proId         String
  pro           User          @relation("ProInvoices", fields: [proId], references: [id], onDelete: Cascade)
  clientId      String
  client        User          @relation("ClientInvoices", fields: [clientId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id])
  retainerId    String?
  retainer      RetainerAgreement? @relation(fields: [retainerId], references: [id])

  items         InvoiceItem[]
  subtotal      Float
  tax           Float?
  total         Float
  currency      String        @default("GBP")
  status        InvoiceStatus @default(draft)
  dueDate       DateTime
  paidAt        DateTime?
  paymentMethod String?
  stripePaymentIntentId String?
  notes         String?

  // Escrow / Milestone integration
  isEscrow      Boolean       @default(false)
  escrowStatus  EscrowStatus? 
  milestoneTitle String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model InvoiceItem {
  id          String   @id @default(cuid())
  description String
  quantity    Int
  unitPrice   Float
  total       Float
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
}

model ScheduledCall {
  id          String              @id @default(cuid())
  proId       String
  pro         User                @relation("ProScheduledCalls", fields: [proId], references: [id], onDelete: Cascade)
  contactName String
  contactId   String?
  scheduledAt DateTime
  duration    Int                 @default(30) // minutes
  callType    CallType            @default(video)
  topic       String?
  status      ScheduledCallStatus @default(pending)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

// ─── Proposal ─────────────────────────────────────────────────────────────────

model Proposal {
  id          String         @id @default(cuid())
  proId       String
  pro         User           @relation("ProProposals", fields: [proId], references: [id], onDelete: Cascade)
  clientId    String
  client      User           @relation("ClientProposals", fields: [clientId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id])

  title       String
  summary     String
  scope       String         // detailed scope of work
  deliverables String[]      // list of deliverable descriptions
  timeline    String         // e.g. "8 weeks"
  price       Float
  currency    String         @default("GBP")
  validUntil  DateTime?

  status      ProposalStatus @default(draft)
  acceptedAt  DateTime?
  rejectedAt  DateTime?
  rejectionNote String?
  notes       String?

  contract    Contract?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

// ─── Contract ─────────────────────────────────────────────────────────────────

model Contract {
  id           String         @id @default(cuid())
  proId        String
  pro          User           @relation("ProContracts", fields: [proId], references: [id], onDelete: Cascade)
  clientId     String
  client       User           @relation("ClientContracts", fields: [clientId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id])
  proposalId   String?        @unique
  proposal     Proposal?      @relation(fields: [proposalId], references: [id])

  title        String
  content      String         // full contract body (markdown/rich text)
  value        Float?
  currency     String         @default("GBP")

  status       ContractStatus @default(draft)
  proSignedAt  DateTime?
  clientSignedAt DateTime?
  expiresAt    DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

// ─── Retainer Agreement ───────────────────────────────────────────────────────

model RetainerAgreement {
  id             String        @id @default(cuid())
  proId          String
  pro          User          @relation("ProRetainers", fields: [proId], references: [id], onDelete: Cascade)
  clientId       String
  client         User          @relation("ClientRetainers", fields: [clientId], references: [id], onDelete: Cascade)

  title          String
  description    String?
  monthlyRate    Float
  currency       String        @default("GBP")
  hoursIncluded  Int?          // included hours per month
  billingDay     Int           @default(1) // day of month to auto-invoice
  startDate      DateTime
  endDate        DateTime?

  status         RetainerStatus @default(active)
  stripeSubscriptionId String?

  invoices       Invoice[]
  timeEntries    TimeEntry[]

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ─── Time Entry ───────────────────────────────────────────────────────────────

model TimeEntry {
  id          String             @id @default(cuid())
  proId       String
  pro         User               @relation(fields: [proId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?           @relation(fields: [projectId], references: [id])
  retainerId  String?
  retainer    RetainerAgreement? @relation(fields: [retainerId], references: [id])

  description String
  hours       Float
  date        DateTime
  billable    Boolean            @default(true)
  invoiced    Boolean            @default(false)

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

// ─── Campaign ─────────────────────────────────────────────────────────────────

model Campaign {
  id          String           @id @default(cuid())
  proId       String
  pro         User             @relation("ProCampaigns", fields: [proId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id])

  name        String
  platform    CampaignPlatform @default(other)
  objective   String?
  startDate   DateTime
  endDate     DateTime?
  budget      Float?
  currency    String           @default("GBP")
  status      CampaignStatus   @default(draft)

  // Aggregate metrics (updated periodically)
  impressions  Int             @default(0)
  clicks       Int             @default(0)
  conversions  Int             @default(0)
  spend        Float           @default(0)
  revenue      Float           @default(0)

  dailyMetrics CampaignMetric[]

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model CampaignMetric {
  id          String   @id @default(cuid())
  campaignId  String
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  date        DateTime @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  spend       Float    @default(0)
  revenue     Float    @default(0)

  @@unique([campaignId, date])
}

// ─── Content Calendar ─────────────────────────────────────────────────────────

model ContentItem {
  id             String        @id @default(cuid())
  proId          String
  pro            User          @relation(fields: [proId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?      @relation(fields: [projectId], references: [id])

  title          String
  type           ContentType   @default(post)
  platform       String?       // e.g. "Instagram", "Facebook"
  content        String?       // body copy
  caption        String?
  fileUrl        String?
  scheduledAt    DateTime?
  publishedAt    DateTime?
  status         ContentStatus @default(draft)

  // Approval
  approvalStatus ApprovalStatus @default(pending_review)
  approvedAt     DateTime?
  rejectionNote  String?

  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

// ─── Brand Asset Manager ──────────────────────────────────────────────────────

model BrandAsset {
  id         String     @id @default(cuid())
  proId      String
  pro       User       @relation(fields: [proId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project?   @relation(fields: [projectId], references: [id])
  clientName String?    // for reference without a project

  name       String
  type       AssetType  @default(other)
  fileUrl    String
  mimeType   String?
  sizeBytes  Int?
  notes      String?

  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

// ─── Project Brief (submitted by client) ─────────────────────────────────────

model ProjectBrief {
  id              String    @id @default(cuid())
  clientId        String
  client          User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId       String?   @unique
  project         Project?  @relation(fields: [projectId], references: [id])

  title           String
  objective       String
  targetAudience  String?
  budget          Float?
  currency        String    @default("GBP")
  platforms       String[]
  deliverables    String[]
  timeline        String?
  additionalNotes String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ─── Team Member (Agency Accounts) ───────────────────────────────────────────

model TeamMember {
  id        String    @id @default(cuid())
  agencyId  String
  agency    User      @relation("AgencyTeam", fields: [agencyId], references: [id], onDelete: Cascade)
  memberId  String
  member    User      @relation("MemberOf", fields: [memberId], references: [id], onDelete: Cascade)
  role      TeamRole  @default(contributor)
  createdAt DateTime  @default(now())

  @@unique([agencyId, memberId])
}

// ─── Scheduled Report ─────────────────────────────────────────────────────────

model ScheduledReport {
  id          String        @id @default(cuid())
  proId       String
  pro         User          @relation(fields: [proId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id])

  title       String
  cadence     ReportCadence @default(monthly)
  recipients  String[]      // email addresses
  lastSentAt  DateTime?
  nextSendAt  DateTime?
  active      Boolean       @default(true)

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // e.g., 'message', 'project', 'system'
  link      String?  // Optional link to navigate to
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model Inquiry {
  id        String        @id @default(cuid())
  proId     String
  pro       User          @relation("ProInquiries", fields: [proId], references: [id], onDelete: Cascade)
  clientId  String
  client    User          @relation("ClientInquiries", fields: [clientId], references: [id], onDelete: Cascade)
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  message   String?
  status    InquiryStatus @default(new)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  Message[]

  @@unique([proId, projectId])
  @@index([proId])
  @@index([clientId])
}

model Message {
  id         String   @id @default(cuid())
  text       String
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  inquiryId  String?
  inquiry    Inquiry? @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([senderId])
  @@index([receiverId])
  @@index([projectId])
  @@index([inquiryId])
}
